# Redis (job queue)
REDIS_HOST=redis
REDIS_PORT=6379

# Shown in notification messages, and used as the root folder name for
# Google Drive uploads (blank falls back to "Backups")
PROJECT_NAME=

# Notification channels (Telegram bot/chat, etc.) are managed entirely from
# the admin UI's "Thông báo" page, not env vars — see notify_channels in
# the registry.

# Google OAuth client (the app's identity, downloaded from Google Cloud
# Console — shared by every Google account you connect from the admin UI's
# "Nơi lưu trữ" page). Per-account tokens are stored in SQLite, not on disk.
GOOGLE_CREDENTIALS_FILE=/app/google/credentials.json

# SQLite registry: databases, their backup schedules, and storage
# destinations (Google Drive accounts / S3 buckets) — all managed from the
# admin web UI.
SQLITE_PATH=/app/data/backupdb.sqlite3

# IANA timezone that backup schedules' HH:MM times are interpreted in, both
# by the scheduler and in the admin UI's labels. One zone for the whole
# deployment (schedules don't carry their own timezone).
SCHEDULER_TIMEZONE=Asia/Ho_Chi_Minh

# Admin web UI (basic auth) — leave blank to disable auth (not recommended
# unless the port is never published outside a trusted network)
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_PORT=8080
