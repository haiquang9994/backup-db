# Redis (job queue)
REDIS_HOST=redis
REDIS_PORT=6379

# Shown in notification messages, and used as the root folder name for
# Google Drive uploads (blank falls back to "Backups")
PROJECT_NAME=

# Notification channels (Telegram bot/chat, etc.) are managed entirely from
# the admin UI's "Thông báo" page, not env vars — see notify_channels in
# the registry.

# Google OAuth client (the app's identity, downloaded from Google Cloud
# Console — shared by every Google account you connect from the admin UI's
# "Nơi lưu trữ" page). Per-account tokens are stored in SQLite, not on disk.
GOOGLE_CREDENTIALS_FILE=/app/google/credentials.json

# SQLite registry: databases, their backup schedules, and storage
# destinations (Google Drive accounts / S3 buckets) — all managed from the
# admin web UI.
SQLITE_PATH=/app/data/backupdb.sqlite3

# IANA timezone that backup schedules' HH:MM times are interpreted in, both
# by the scheduler and in the admin UI's labels. One zone for the whole
# deployment (schedules don't carry their own timezone).
SCHEDULER_TIMEZONE=Asia/Ho_Chi_Minh

# Admin web UI (basic auth) — leave blank to disable auth (not recommended
# unless the port is never published outside a trusted network)
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_PORT=8080

# ---------------------------------------------------------------------------
# `agent` subcommand only — a standalone server you run on a *different*
# machine, for a database this deployment can't reach any other way (see
# README.md, "Backup database trên server khác (agent)"). Not read by
# admin/scheduler/consumer, so leave blank on the main deployment's .env.
# ---------------------------------------------------------------------------

# Shared secret this agent requires on every request — generate a long
# random value (e.g. `openssl rand -hex 32`) and paste the same value into
# the central admin UI when registering this agent there. Required to start.
AGENT_TOKEN=

# Port this agent's HTTPS server listens on. Needs to be reachable from the
# central server, so open it in *this* machine's firewall — the central
# server itself never needs to open anything.
AGENT_PORT=8443

# Where this agent persists its self-signed TLS certificate across
# restarts. Losing it changes the fingerprint pinned in the central admin
# UI, breaking every database routed through this agent until re-pinned —
# make sure this path is on a volume that survives container recreation.
AGENT_CERT_FILE=/app/data/agent-cert.pem
AGENT_KEY_FILE=/app/data/agent-key.pem
